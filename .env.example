# ============================================================
# XRPL 99%+ Arbitrage Bot — Environment Variables
# ============================================================
# Copy this file: cp .env.example .env
# Then fill in your actual values. Never commit .env to git.
# ============================================================

# --- XRPL Connection ---

# Your XRPL wallet seed (family seed format: sXXXXX...).
# REQUIRED for live trading. In DRY_RUN=True mode the bot still
# needs this to derive your wallet address for balance checks.
# Generate a new wallet at: https://xrpl.org/xrp-testnet-faucet.html
XRPL_SECRET=your_wallet_seed_here

# XRPL mainnet WebSocket node. Must start with wss:// (TLS enforced).
# Default uses Ripple's public node. For lower latency, consider a
# private node (e.g. XRPL Cluster or Ripple's hosted nodes).
# NOTE: s1.ripple.com may route to Clio (read-only) servers which don't
# fully support ripple_path_find. Use s2.ripple.com or xrplcluster.com
# for more reliable path finding results.
XRPL_WS_URL=wss://s2.ripple.com

# XRPL mainnet RPC URL used for simulate calls and balance checks.
# Must be a full rippled node (not Clio) for ripple_path_find support.
# Options: https://s2.ripple.com:51234, https://xrplcluster.com
XRPL_RPC_URL=https://s2.ripple.com:51234

# --- Trading Parameters ---

# Paper trading mode. True = logs opportunities without submitting
# transactions. FALSE = LIVE TRADING — real XRP will be spent.
# ALWAYS start with True and run for at least 7 days before switching.
DRY_RUN=True

# Minimum net profit required before a trade is considered (after
# network fee and slippage buffer). Default 0.006 = 0.6%.
# Lowering this increases trade frequency but reduces win certainty.
# Do not go below 0.003 without extensive backtesting.
#
# IMPORTANT (post Codex audit 2026-04-23 Finding #2): this base
# PROFIT_THRESHOLD is used by legacy single-tier scripts (e.g.
# scripts/diagnose_two_leg.py) and for some startup banner displays.
# The live scanner uses the tiered values below (HIGH_LIQ / LOW_LIQ).
# To change runtime behavior you MUST set all three — setting only
# PROFIT_THRESHOLD leaves the tiered values untouched and the scanner
# continues to gate on the tiered defaults.
PROFIT_THRESHOLD=0.006

# Maximum position size as a fraction of your current XRP balance.
# Default 0.05 = 5%. At 10 XRP balance, max trade is 0.5 XRP.
# Keep this low while learning the bot's behavior.
MAX_POSITION_PCT=0.05

# Daily loss circuit breaker. If cumulative losses reach this fraction
# of balance, the bot stops scanning for 24 hours.
# Default 0.02 = 2%. Set lower (e.g. 0.01) for extra caution.
DAILY_LOSS_LIMIT_PCT=0.02

# LastLedgerSequence offset applied to BOTH legs of an atomic two-leg
# arbitrage submission. At 4 ledgers (~20s) this matches the legacy
# hardcode. Both legs share the same ledger deadline so leg 2 cannot
# outlive leg 1's window. Lower = safer against orphan replay.
LEG2_TIMEOUT_LEDGERS=4

# Base slippage buffer added to profit calculation.
# Default 0.003 = 0.3%. Accounts for XRPL order book movement.
SLIPPAGE_BASE=0.003

# --- HIGH_LIQ Currencies (arbitrage route universe) ---
# Comma-separated currency codes the scanner treats as "high liquidity"
# (uses PROFIT_THRESHOLD_HIGH_LIQ instead of the base/low-liq threshold).
# To add a currency: append its code here AND ensure a trust line is set
# (see scripts/setup_trust_lines.py). Restart the bot to pick up changes.
HIGH_LIQ_CURRENCIES=USD,USDC,RLUSD,EUR,SOLO,USDT

# Trusted issuer addresses for HIGH_LIQ currencies. The scanner uses
# these via ripple_path_find; these addresses MUST match trust lines
# provisioned by scripts/setup_trust_lines.py.
#   USD   Bitstamp  rvYAfWj5gh67oV6fW32ZzP3Aw4Eubs59B
#   USD   GateHub   rhub8VRN55s94qWKDv6jmDy1pUykJzF3wq
#   USDC  Circle    rGm7WCVp9gb4jZHWTEtGUr4dd74z2XuWhE  (hex: 5553444300000000000000000000000000000000)
#   RLUSD Ripple    rMxCKbEDwqr76QuheSUMdEGf4B9xJ8m5De  (hex: 524C555344000000000000000000000000000000)
#   EUR   GateHub   rhub8VRN55s94qWKDv6jmDy1pUykJzF3wq
#   SOLO  Sologenic rsoLo2S1kiGeCcn6hCUXVrCpGMWLrRrLZz  (hex: 534F4C4F00000000000000000000000000000000)
#   USDT  GateHub   rcvxE9PS9YBwxtGg1qNeewV6ZB3wGubZq   (hex: 5553445400000000000000000000000000000000)

# Profit threshold overrides by liquidity class.
# HIGH_LIQ: 0.3% — deep books, low slippage (USD, USDC, RLUSD, EUR, SOLO, USDT)
# LOW_LIQ:  1.0% — thinner books (all other IOU currencies)
#
# These two vars are what the scanner ACTUALLY gates on — PROFIT_THRESHOLD
# above is only a legacy reference. When tuning, change both of these.
PROFIT_THRESHOLD_HIGH_LIQ=0.003
PROFIT_THRESHOLD_LOW_LIQ=0.010

# --- Telegram Alerts (Optional) ---
# Leave blank to disable — the bot runs fine without Telegram.

# BotFather token (format: 1234567890:ABCDEFxxxxxxxx)
# Create a bot at https://t.me/BotFather
TELEGRAM_TOKEN=

# Your Telegram chat ID. Find it via @userinfobot or @RawDataBot.
TELEGRAM_CHAT_ID=

# --- AI Brain (Optional) ---
# Leave blank to disable Claude post-trade analysis.
# The bot runs fully without this — it only affects pattern suggestions.

# Anthropic API key (format: sk-ant-xxxx...)
# Get one at https://console.anthropic.com/
ANTHROPIC_KEY=

# File where AI trade review JSON responses are appended.
AI_REVIEWS_FILE=ai_reviews.jsonl

# --- Logging ---

# Path to the JSONL trade log shared between bot and dashboard.
# Use an absolute path on the VPS to avoid working-directory issues.
LOG_FILE=xrpl_arb_log.jsonl

# Python logging level. INFO is recommended for production.
# Use DEBUG to see every scan cycle during initial testing.
LOG_LEVEL=INFO
